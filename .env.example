# ===========================================
# PD's Lab Chatbot - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# .env is gitignored and will NEVER be committed to GitHub
# ===========================================

# ---- LLM API (火山引擎 Coding Plan) ----
LLM_API_KEY=
LLM_API_BASE=https://ark.cn-beijing.volces.com/api/coding/v3
LLM_MODEL=doubao-seed-2.0-lite

# ---- Discord Webhook (visitor notifications) ----
# Create at: Discord channel -> Settings -> Integrations -> Webhooks -> New Webhook
DISCORD_WEBHOOK_URL=

# ---- Cloudflare Deployment ----
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ---- Chatbot Config ----
MAX_MESSAGES=30
RATE_LIMIT=10
